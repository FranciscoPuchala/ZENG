# ZENG - Variables de entorno del servidor
# Copiar este archivo a api/.env y completar los valores

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zeng
DB_USER=postgres
DB_PASSWORD=

# Seguridad JWT (generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=

# Puerto del servidor (la app web corre en este puerto)
PORT=3001

# Backups
BACKUP_DESTINO=D:\
BACKUP_LOG=D:\backups_zeng\backup.log

# Ruta al bin de PostgreSQL (donde estan pg_dump.exe y pg_restore.exe)
PG_BIN=C:\Program Files\PostgreSQL\18\bin
